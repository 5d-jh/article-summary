{
  "name": "mygist",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node build.js",
    "zip:firefox": "cd dist/firefox && zip -r ../firefox.zip ./*",
    "zip:chrome": "cd dist/chrome && zip -r ../chrome.zip ./*",
    "zip": "node build.js -v $(git describe --tags --abbrev=0) && pnpm run zip:firefox && pnpm run zip:chrome"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.3.2",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.27.3",
    "marked": "^17.0.5",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "webextension-polyfill": "^0.12.0"
  }
}